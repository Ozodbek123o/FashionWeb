{
	"name": "fashion-backend",
	"version": "1.0.0",
	"description": "BTEC Unit 6 Fashion Wholesale Backend",
	"main": "dist/server.js",
	"scripts": {
		"start": "node dist/server.js",
		"dev": "nodemon src/server.ts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"ci": "npm run typecheck && npm run test && npm run build",
		"build": "tsc",
		"postinstall": "prisma generate",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate dev",
		"prisma:deploy": "prisma migrate deploy"
	},
	"dependencies": {
		"@prisma/client": "^5.11.0",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"express": "^4.19.2",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/node": "^20.11.30",
		"nodemon": "^3.1.0",
		"prisma": "^5.11.0",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.3",
		"vitest": "^2.1.8"
	}
}
